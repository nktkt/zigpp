// expected stderr: hello, zigpp!\n
const std = @import("std");

trait Greeter {
    fn greet(self) void;
}

const Hello = struct {
    name: []const u8,
    pub fn greet(self: *Hello) void {
        std.debug.print("hello, {s}!\n", .{self.name});
    }
};

pub fn main() void {
    var hello = Hello{ .name = "zigpp" };
    const g: Greeter = Greeter.from(&hello);
    g.greet();
}
